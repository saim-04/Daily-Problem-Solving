#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n, target;
    cin >> n >> target;
    vector<int> nums(n);
    for (int i = 0; i < n; i++)
    {
        cin >> nums[i];
    }

    int result = 0;

    for (int i = 0; i < n; i++)
    {
        int count = 0;
        for (int j = i; j < n; j++)
        {
            if (nums[j] == target)
            {
                count++;
            }
            if (count * 2 > (j - i + 1))
            {
                result++;
            }
        }
    }
    cout << result << endl;
    return 0;
}
