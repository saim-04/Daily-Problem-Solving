#include <bits/stdc++.h>
using namespace std;
int main()
{

    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n;
    cin >> n;

    vector<long long> x(n);
    for (int i = 0; i < n; i++)
    {
        cin >> x[i];
    }
    sort(x.begin(), x.end());

    long long reach = 1;

    for (int i = 0; i < n; i++)
    {
        if (x[i] > reach)
            break;
        reach += x[i];
    }

    cout << reach << endl;
    return 0;
}
